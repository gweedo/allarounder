{
  "name": "Allarounder (FastAPI + Next.js)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/Podcast Blog Build",

  // --- Tooling layered in via devcontainer features -----------------------
  "features": {
    // Node 20 LTS + corepack (pnpm enabled in postCreate).
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    // Docker-in-Docker so testcontainers can launch ephemeral containers
    // (e.g. throwaway Postgres for integration tests) from inside `app`.
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    // Azure CLI with the Bicep extension for infra/ IaC.
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "installBicep": true
    },
    // GitHub CLI for PRs, Actions, and OIDC workflow tasks.
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // Claude Code CLI (installs the `claude` binary; needs the Node feature).
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },

  // Postgres `db` service comes up alongside `app`.
  "runServices": ["db"],

  // Backend (FastAPI/uvicorn) and frontend (Next.js) dev ports.
  "forwardPorts": [8000, 3000],

  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  // --- Editor configuration (VS Code) -------------------------------------
  "customizations": {
    "vscode": {
      "extensions": [
        // Python / backend
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        // TypeScript / frontend
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        // Infra / DevOps
        "ms-azuretools.vscode-bicep",
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        // DB
        "ms-ossdata.vscode-pgsql",
        // Claude Code
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll": "explicit",
          "source.organizeImports": "explicit"
        },
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "[javascript][javascriptreact][typescript][typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "python.defaultInterpreterPath": "/workspaces/Podcast Blog Build/src/backend/.venv/bin/python",
        "python.testing.pytestEnabled": true
      }
    }
  },

  // Run as the non-root user provided by the base image.
  "remoteUser": "vscode"
}
