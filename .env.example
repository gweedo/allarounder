# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Backend ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (used by FastAPI + Alembic)
DATABASE_URL=postgresql+psycopg://allarounder:allarounder@db:5432/allarounder

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production

# Application environment: development | staging | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Azure Blob Storage (for image uploads)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=images
AZURE_CDN_BASE_URL=https://cdn.allarounder.it/images

# ── Frontend ─────────────────────────────────────────────────────────────────

# Backend API base URL (server-side Next.js calls)
NEXT_PUBLIC_API_URL=http://localhost:8000
